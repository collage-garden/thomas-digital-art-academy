---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Works" description="Things we made with what we learned">
  <h1>Works</h1>
  <p><em>The fruit of the garden.</em></p>
  <p>
    Per our <a href="../charter/">Charter</a>, an exhibited work is not finished — it is <em>doing</em>.
    Works may be born from any scene path or at the intersection of multiple paths.
  </p>
  <hr />
  <h2>Works</h2>
  <div class="works-grid">
    <a href="https://collage-garden.github.io/binaural-beats/" class="work-card">
      <span class="work-icon">🎧</span>
      <strong>Binaural Beats Explorer</strong>
      <span class="work-meta">Scenes: Auditory Art · Interactive Installation</span>
      <span class="work-desc">An interactive binaural beats experience tool. Three audio modes (Pure Tone, Music SSB, Drone), four frequency distribution strategies, real-time visualization, PWA offline support. Pure frontend, zero dependencies — Web Audio API, AudioWorklet, FFT-based SSB modulation.</span>
      <span class="work-tags">
        <span class="tag">web-audio</span>
        <span class="tag">psychoacoustics</span>
        <span class="tag">pwa</span>
        <span class="ai-label">AI co-creation</span>
      </span>
    </a>
  </div>
</BaseLayout>

<style>
  .works-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
    margin: 1.5rem 0;
  }
  .work-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .work-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 2px 8px rgba(45, 106, 79, 0.1);
  }
  .work-icon { font-size: 1.8rem; margin-bottom: 0.5rem; }
  .work-card strong { font-family: var(--font-heading); margin-bottom: 0.25rem; }
  .work-meta { font-size: 0.8rem; color: var(--color-accent); margin-bottom: 0.5rem; }
  .work-desc { font-size: 0.85rem; color: var(--color-muted); margin-bottom: 0.75rem; }
  .work-tags { display: flex; flex-wrap: wrap; gap: 0.25rem; }
</style>
