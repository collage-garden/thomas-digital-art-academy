---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
const loc = `${base}zh-cn/`;

const scenes = [
  { slug: 'everyday-life', icon: '🌿', title: '日常生活', desc: '隐藏在日常中的艺术与科学' },
  { slug: 'social-observation', icon: '🔭', title: '社会观察', desc: '社会如何运转、人如何互动、文化如何演变' },
  { slug: 'auditory-art', icon: '🎵', title: '听觉艺术', desc: '声音、音乐、声学，以及聆听的体验' },
  { slug: 'visual-art', icon: '🎨', title: '视觉艺术', desc: '图像、形态、色彩、空间，以及观看的体验' },
  { slug: 'interactive-installation', icon: '🕳️', title: '互动装置', desc: '技术与物理空间、人的参与相遇的地方' },
  { slug: 'traditional-art', icon: '🎭', title: '传统艺术', desc: '以现代视角重新审视古老技艺' },
];
---

<BaseLayout title="场景" description="托马斯数字艺术学园的六条花园小径">
  <h1>花园小径</h1>
  <p>穿过花园的六条彼此交叉的路径。它们自由交错——一个项目可能生长在两三条路径的交汇处。</p>

  <div class="scenes-grid">
    {scenes.map(s => (
      <a href={`${loc}scenes/${s.slug}/`} class="scene-card">
        <span class="scene-icon">{s.icon}</span>
        <strong>{s.title}</strong>
        <span class="scene-desc">{s.desc}</span>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .scenes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
    margin: 2rem 0;
  }
  .scene-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .scene-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 2px 8px rgba(45, 106, 79, 0.1);
  }
  .scene-icon { font-size: 1.8rem; margin-bottom: 0.5rem; }
  .scene-card strong { font-family: var(--font-heading); margin-bottom: 0.25rem; }
  .scene-desc { font-size: 0.85rem; color: var(--color-muted); }
</style>
