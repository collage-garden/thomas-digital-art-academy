---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const disciplines = [
  { slug: 'physics', title: '物理学', desc: '力学、声学、光学、热力学、电磁学' },
  { slug: 'mathematics', title: '数学', desc: '几何、代数、微积分、统计学、信号、信息论' },
  { slug: 'economics', title: '经济学', desc: '市场、行为经济学、博弈论、资源配置' },
  { slug: 'philosophy', title: '哲学', desc: '美学、认识论、伦理学、逻辑学、现象学' },
  { slug: 'psychology', title: '心理学', desc: '感知、认知、情感、创造力、行为模式' },
  { slug: 'physiology', title: '生理学', desc: '感觉系统、运动控制、具身体验' },
  { slug: 'neuroscience', title: '神经科学', desc: '神经处理、听觉/视觉皮层、可塑性、意识' },
];
---

<BaseLayout title="知识" description="工具架，不是课表">
  <h1>知识碎片</h1>
  <p><em>工具架，不是课表。</em></p>
  <p>
    你不是来这里"学物理"的。你来这里是因为你在做东西，
    需要理解一根弦为什么那样振动。拿走你需要的，然后回去继续工作。
  </p>
  <hr />
  <div class="knowledge-grid">
    {disciplines.map(d => (
      <div class="discipline-card">
        <strong>{d.title}</strong>
        <span>{d.desc}</span>
      </div>
    ))}
  </div>
  <p class="hint"><em>如果你发现自己在这里花的时间比在场景里更多，你可能迷路了。去做点什么吧。</em></p>
</BaseLayout>

<style>
  .knowledge-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
    margin: 2rem 0;
  }
  .discipline-card {
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }
  .discipline-card strong { font-family: var(--font-heading); margin-bottom: 0.25rem; }
  .discipline-card span { font-size: 0.85rem; color: var(--color-muted); }
  .hint { margin-top: 2rem; color: var(--color-muted); }
</style>
