---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const disciplines = [
  { slug: 'physics', title: 'Physics', desc: 'Mechanics, acoustics, optics, thermodynamics, electromagnetism' },
  { slug: 'mathematics', title: 'Mathematics', desc: 'Geometry, algebra, calculus, statistics, signals, information theory' },
  { slug: 'economics', title: 'Economics', desc: 'Markets, behavioral economics, game theory, resource allocation' },
  { slug: 'philosophy', title: 'Philosophy', desc: 'Aesthetics, epistemology, ethics, logic, phenomenology' },
  { slug: 'psychology', title: 'Psychology', desc: 'Perception, cognition, emotion, creativity, behavioral patterns' },
  { slug: 'physiology', title: 'Physiology', desc: 'Sensory systems, motor control, embodied experience' },
  { slug: 'neuroscience', title: 'Neuroscience', desc: 'Neural processing, auditory/visual cortex, plasticity, consciousness' },
];
---

<BaseLayout title="Knowledge" description="The toolkit, not the curriculum">
  <h1>Knowledge Fragments</h1>
  <p><em>The toolkit, not the curriculum.</em></p>
  <p>
    You don't come here to "study physics." You come here because you're making something
    and need to understand why a string vibrates the way it does. Take what you need and go back to your work.
  </p>
  <hr />
  <div class="knowledge-grid">
    {disciplines.map(d => (
      <div class="discipline-card">
        <strong>{d.title}</strong>
        <span>{d.desc}</span>
      </div>
    ))}
  </div>
  <p class="hint"><em>If you find yourself spending more time here than in the scenes, you might be lost. Go make something.</em></p>
</BaseLayout>

<style>
  .knowledge-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
    margin: 2rem 0;
  }
  .discipline-card {
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }
  .discipline-card strong { font-family: var(--font-heading); margin-bottom: 0.25rem; }
  .discipline-card span { font-size: 0.85rem; color: var(--color-muted); }
  .hint { margin-top: 2rem; color: var(--color-muted); }
</style>
