---
import BaseLayout from '../layouts/BaseLayout.astro';
import { marked } from 'marked';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  const root = process.cwd();
  const pages: { params: { slug: string | undefined }; props: { file: string } }[] = [];
  const contentDirs = ['scenes', 'stories', 'knowledge', 'works', 'courses'];

  // Homepage
  pages.push({ params: { slug: undefined }, props: { file: 'README.md' } });

  // Charter (special file, not inside a content dir)
  if (fs.existsSync(path.join(root, 'CHARTER.md'))) {
    pages.push({ params: { slug: 'charter' }, props: { file: 'CHARTER.md' } });
  }

  // Recursively scan content directories for README.md
  function scan(dir: string) {
    const abs = path.join(root, dir);
    if (!fs.existsSync(abs)) return;
    if (fs.existsSync(path.join(abs, 'README.md'))) {
      pages.push({ params: { slug: dir }, props: { file: `${dir}/README.md` } });
    }
    for (const entry of fs.readdirSync(abs, { withFileTypes: true })) {
      if (entry.isDirectory() && !entry.name.startsWith('.')) {
        scan(`${dir}/${entry.name}`);
      }
    }
  }

  for (const dir of contentDirs) scan(dir);
  return pages;
}

const { file } = Astro.props;
const raw = fs.readFileSync(path.resolve(file), 'utf-8');
const titleMatch = raw.match(/^#\s+(.+)$/m);
const title = titleMatch ? titleMatch[1].replace(/\*.*?\*/g, '').trim() : 'Page';
let html = await marked(raw);

html = html.replace(/href="([^"]*?)CHARTER\.md"/g, 'href="$1charter/"');
html = html.replace(/href="([^"]*?)CHARTER-ZH\.md"/g, 'href="$1charter/"');
---

<BaseLayout title={title}>
  <article set:html={html} />
</BaseLayout>
