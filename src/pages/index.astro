---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<BaseLayout title="Home">
  <section class="hero">
    <h1>Thomas's Digital Art Academy</h1>
    <p class="tagline"><em>The Collage Garden · 托马斯数字艺术学园 · 拼贴花园</em></p>
    <blockquote>
      Our education is not about teaching students to get things right.
      It is about teaching them how to fail at the lowest possible cost,
      and how to learn and improve their work through continuous failure.
    </blockquote>
  </section>

  <section>
    <h2>What Is This?</h2>
    <p>
      A garden where a technologist learns to make art — and invites you to walk alongside.
      This is not a course platform. This is a living, versioned record of learning:
      rough drafts, wrong turns, small discoveries, and works-in-progress.
      Everything here is <em>doing</em>, never done.
    </p>
  </section>

  <section>
    <h2>Garden Paths</h2>
    <div class="paths">
      <a href={`${base}scenes/everyday-life/`} class="path-card">
        <span class="path-icon">🌿</span>
        <strong>Everyday Life</strong>
        <span>The art and science hidden in daily routines</span>
      </a>
      <a href={`${base}scenes/social-observation/`} class="path-card">
        <span class="path-icon">🔭</span>
        <strong>Social Observation</strong>
        <span>How societies work, how people interact, how cultures evolve</span>
      </a>
      <a href={`${base}scenes/auditory-art/`} class="path-card">
        <span class="path-icon">🎵</span>
        <strong>Auditory Art</strong>
        <span>Sound, music, acoustics, and the experience of listening</span>
      </a>
      <a href={`${base}scenes/visual-art/`} class="path-card">
        <span class="path-icon">🎨</span>
        <strong>Visual Art</strong>
        <span>Image, form, color, space, and the experience of seeing</span>
      </a>
      <a href={`${base}scenes/interactive-installation/`} class="path-card">
        <span class="path-icon">🕳️</span>
        <strong>Interactive Installation</strong>
        <span>Where technology meets physical space and human participation</span>
      </a>
      <a href={`${base}scenes/traditional-art/`} class="path-card">
        <span class="path-icon">🎭</span>
        <strong>Traditional Art</strong>
        <span>Ancient craft through modern eyes</span>
      </a>
    </div>
  </section>

  <section>
    <h2>Explore</h2>
    <p>
      <a href={`${base}stories/`}>Stories</a> — the creative process, documented honestly<br />
      <a href={`${base}knowledge/`}>Knowledge</a> — the toolkit, not the curriculum<br />
      <a href={`${base}works/`}>Works</a> — things we made with what we learned<br />
      <a href={`${base}courses/`}>Courses</a> — curated walks through the garden<br />
      <a href={`${base}charter/`}>Charter</a> — the constitution of this garden
    </p>
  </section>

  <section>
    <h2>Start Walking</h2>
    <p>
      Read the <a href={`${base}charter/`}>Charter</a> first.
      Then pick any path that interests you. There are no prerequisites, no deadlines, and no wrong turns.
    </p>
  </section>
</BaseLayout>

<style>
  .hero {
    margin-bottom: 3rem;
  }
  .hero h1 {
    margin-top: 0;
  }
  .tagline {
    color: var(--color-muted);
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
  }
  .paths {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    margin: 1.5rem 0;
  }
  .path-card {
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .path-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 2px 8px rgba(45, 106, 79, 0.1);
  }
  .path-icon {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .path-card strong {
    font-family: var(--font-heading);
    margin-bottom: 0.25rem;
  }
  .path-card span:last-child {
    font-size: 0.85rem;
    color: var(--color-muted);
  }
</style>
