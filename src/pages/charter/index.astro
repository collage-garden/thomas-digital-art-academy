---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { marked } from 'marked';
import fs from 'node:fs';
import path from 'node:path';

const charterPath = path.resolve('CHARTER.md');
const charterContent = fs.readFileSync(charterPath, 'utf-8');
const html = await marked(charterContent);
---

<BaseLayout title="Charter" description="The constitution of Thomas's Digital Art Academy">
  <article set:html={html} />
</BaseLayout>
